HOST=0.0.0.0
PORT=8000

ADMIN_USERNAME=admin
ADMIN_PASSWORD=professortux

# Ollama endpoint (local or remote). For cloud models, run `ollama signin` on
# this host — the local daemon forwards :*-cloud models to Ollama Cloud.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_KEEP_ALIVE=5m

# Optional: enables the CTF web_search tool through Ollama's cloud web API.
# You can also paste this key in the admin page. Chat still uses OLLAMA_BASE_URL.
OLLAMA_API_KEY=
OLLAMA_WEB_SEARCH_BASE_URL=https://ollama.com

# Generation
MAX_TOKENS=1024
TEMPERATURE=0.7
MODEL_REQUEST_TIMEOUT=60

# Logging
CHAT_LOG_DIR=./data/logs
